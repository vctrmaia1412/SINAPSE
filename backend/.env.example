APP_NAME=DevEvents
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# PostgreSQL — alinhado ao docker-compose (postgres:16, user/db devevents)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=devevents
DB_USERNAME=devevents
DB_PASSWORD=devevents_secret

# Em produção (Railway, etc.) use DATABASE_URL; o entrypoint limpa DB_* conflitantes.
# DATABASE_URL=

# Railway (só no painel): RUN_MIGRATIONS_ON_BOOT=true uma vez; RUN_DB_SEED_ON_BOOT=true uma vez (utilizadores de teste).
# RUN_MIGRATIONS_ON_BOOT=
# RUN_DB_SEED_ON_BOOT=

SESSION_DRIVER=array
CACHE_STORE=array

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173
