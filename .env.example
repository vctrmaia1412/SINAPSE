# =============================================================================
# DevEvents — variáveis para Docker Compose (raiz do repositório)
# =============================================================================
# Copie para .env na raiz (opcional): as credenciais padrão já funcionam sem arquivo.
#   copy .env.example .env   (Windows PowerShell: Copy-Item .env.example .env)
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=devevents
POSTGRES_USER=devevents
POSTGRES_PASSWORD=devevents_secret
# Porta no host (ferramentas locais: DBeaver, psql)
POSTGRES_PORT=5432

# --- Laravel (container backend) ---
APP_NAME=DevEvents
APP_ENV=local
APP_DEBUG=true
# URL pública usada pelo browser (porta do frontend)
APP_URL=http://localhost:8080
# Recomendado: defina uma chave fixa para APP_KEY não mudar a cada restart do container
# (senão dados cifrados com a chave anterior ficam inválidos).
# Gerar uma vez (sem rodar o entrypoint / migrate):
#   docker compose run --rm --entrypoint php backend -r "echo 'base64:'.base64_encode(random_bytes(32)).PHP_EOL;"
# Copie a linha "base64:..." para cá (ou use: php -r "echo 'base64:'.base64_encode(random_bytes(32)).PHP_EOL;" numa imagem PHP).
# Deixe vazio só para demo única: o entrypoint gera uma chave em memória a cada start.
APP_KEY=

# Portas publicadas no host
BACKEND_PORT=8000
FRONTEND_PORT=8080

# --- Frontend (build Vite: chamadas à API pelo mesmo host, via proxy Nginx) ---
VITE_API_BASE_URL=/api/v1

# --- Sanctum (cookies / SPA; tokens Bearer costumam não depender disso) ---
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,127.0.0.1,127.0.0.1:8080

# =============================================================================
# Após o primeiro up, popular dados de demonstração (uma vez):
#   docker compose exec backend php artisan db:seed --force
#
# Login de exemplo (senha: password):
#   organizer1@devevents.test  |  participant1@devevents.test
# =============================================================================
